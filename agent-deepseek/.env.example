# ─────────────────────────────────────────────────────────────
# agent-deepseek — environment template
# Copy to .env and fill in all required values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── DeepSeek LLM ──────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat
# deepseek-reasoner for complex multi-step audits (slower, more thorough)

# ── Telegram bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use /admin_* commands
ADMIN_TELEGRAM_IDS=

# Message shown to unregistered users
SUPPORT_CONTACT=Для подключения напишите нам: @your_support_handle

# ── Registry encryption ───────────────────────────────────────
# 32-byte master key (64 hex chars). Generate once:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Store ONLY in your secrets manager / server env — never commit.
APP_ENC_KEY=

# Path to the SQLite registry database (default: ./data/registry.db)
# DB_PATH=./data/registry.db

# ── MCP server ────────────────────────────────────────────────
MCP_SERVER_DIR=../MCP 1C v1

# ── Tenant pool ───────────────────────────────────────────────
# MAX_WARM_TENANTS=15
# IDLE_TIMEOUT_MIN=15
# SPAWN_CONCURRENCY=3
# SPAWN_MAX_FAILURES=4

# ── Onboarding ────────────────────────────────────────────────
# TRIAL_DAYS=14

# ── Single-tenant dev / CLI mode (agent.mjs --once) ──────────
# SYSTEM_PROMPT_FILE=../guide/11-deepseek-system-prompt.md
# ONEC_BASE_URL=https://your-1c-server/odata/standard.odata
# ONEC_USERNAME=readonly_user
# ONEC_PASSWORD=secret
