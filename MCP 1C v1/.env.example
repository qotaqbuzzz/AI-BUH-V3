# ── 1C:Enterprise OData connection ─────────────────────────────────
# /odata/standard.odata is appended automatically if absent.
ONEC_BASE_URL=http://<server>/<base>
ONEC_USERNAME=
ONEC_PASSWORD=
ONEC_TIMEOUT_MS=30000
ONEC_MAX_RETRIES=3
ONEC_LOG_LEVEL=info

# ── 1С:Документооборот (СЭД) — optional ────────────────────────────
# Leave empty if 1C:Document Management is not used.
DOCFLOW_BASE_URL=
DOCFLOW_USERNAME=
DOCFLOW_PASSWORD=
DOCFLOW_TIMEOUT_MS=30000
DOCFLOW_MAX_RETRIES=3

# ── LLM digest (onec_generate_full_report) — optional ──────────────
# Любой OpenAI-совместимый провайдер. Пусто → детерминированный отчёт без AI-дайджеста.
# OpenAI:      LLM_BASE_URL=https://api.openai.com/v1        LLM_MODEL=gpt-4o
# OpenRouter:  LLM_BASE_URL=https://openrouter.ai/api/v1     LLM_MODEL=anthropic/claude-sonnet-4
# DeepSeek:    LLM_BASE_URL=https://api.deepseek.com/v1      LLM_MODEL=deepseek-chat
# Ollama:      LLM_BASE_URL=http://localhost:11434/v1        LLM_MODEL=llama3.1   (LLM_API_KEY пусто)
# Anthropic:   LLM_BASE_URL=https://api.anthropic.com/v1     LLM_MODEL=claude-sonnet-4-6
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# ── AI Auditor alerts — optional ───────────────────────────────────
# Telegram: get token from @BotFather, chat_id from @userinfobot
ALERT_TELEGRAM_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
# Generic webhook (Slack-compatible JSON, Teams, custom)
ALERT_WEBHOOK_URL=
# Minimum severity to trigger alerts: info | warn | error
ALERT_MIN_SEVERITY=warn
# Minimum confidence score (0–100) to trigger alerts
ALERT_MIN_CONFIDENCE=60
